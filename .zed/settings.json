{
  "project_name": "prod-files",
  "lsp": {
    "oxlint": {
      "initialization_options": {
        "settings": {
          "run": "onType",
          // "typeAware": true,
          "unusedDisableDirectives": "deny"
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "run": "onSave"
        }
      }
    }
  },
  "languages": {
    "Markdown": {
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [{ "language_server": { "name": "oxfmt" } }]
    },
    "JavaScript": {
      "language_servers": ["vtsls", "oxlint", "oxfmt", "codebook"],
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [
        { "code_action": "source.fixAll.oxc" },
        { "language_server": { "name": "oxfmt" } }
      ]
    },
    "JSON": {
      "language_servers": ["oxfmt", "oxlint", "json-language-server"],
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [
        { "code_action": "source.fixAll.oxc" },
        { "language_server": { "name": "oxfmt" } }
      ]
    },
    "JSONC": {
      "language_servers": ["oxfmt", "oxlint", "json-language-server"],
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [
        { "code_action": "source.fixAll.oxc" },
        { "language_server": { "name": "oxfmt" } }
      ]
    }
  }
}
